{
  "id": "default",
  "name": "Default Pet",
  "version": "1.0.0",
  "width": 260,
  "height": 320,
  "renderer": "sprite",
  "assets": {
    "spriteSheet": "sprite-sheet.svg",
    "frameWidth": 220,
    "frameHeight": 220
  },
  "states": {
    "idle": {
      "frames": [0],
      "fps": 1,
      "loop": true
    },
    "hover": {
      "frames": [1],
      "fps": 1,
      "loop": true
    },
    "click": {
      "frames": [2],
      "fps": 1,
      "loop": false
    },
    "playing": {
      "frames": [3, 4],
      "fps": 4,
      "loop": true
    },
    "paused": {
      "frames": [5],
      "fps": 1,
      "loop": true
    },
    "loading": {
      "frames": [6],
      "fps": 2,
      "loop": true
    },
    "error": {
      "frames": [7],
      "fps": 1,
      "loop": true
    }
  }
}
